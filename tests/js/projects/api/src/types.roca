/// A user with name and age
pub struct User {
    name: String
    age: Number
    create(name: String, age: Number) -> User
}{
    /// Create a user
    pub fn create(name: String, age: Number) -> User {
        return User { name: name, age: age }
    test {
        self("cam", 30) == User { name: "cam", age: 30 }
    }}
}

/// API response
pub struct ApiResponse {
    status: Number
    body: String
    success(body: String) -> ApiResponse
    fail(message: String) -> ApiResponse
}{
    /// Success response
    pub fn success(body: String) -> ApiResponse {
        return ApiResponse { status: 200, body: body }
    test {
        self("ok") == ApiResponse { status: 200, body: "ok" }
    }}

    /// Error response
    pub fn fail(message: String) -> ApiResponse {
        return ApiResponse { status: 400, body: message }
    test {
        self("bad") == ApiResponse { status: 400, body: "bad" }
    }}
}
