// Utility functions — pure logic, no side effects

pub fn clamp(val: Number, min: Number, max: Number) -> Number {
    if val < min { return min }
    if val > max { return max }
    return val

    test {
        self(5, 0, 10) == 5
        self(-5, 0, 10) == 0
        self(50, 0, 10) == 10
        self(0, 0, 10) == 0
        self(10, 0, 10) == 10
    }
}

pub fn pluralize(word: String, count: Number) -> String {
    if count == 1 { return word }
    return word + "s"

    test {
        self("cat", 1) == "cat"
        self("cat", 0) == "cats"
        self("cat", 5) == "cats"
    }
}

pub fn status_message(code: Number) -> String {
    return match code {
        200 => "OK"
        400 => "Bad Request"
        404 => "Not Found"
        500 => "Internal Server Error"
        _ => "Unknown"
    }

    test {
        self(200) == "OK"
        self(400) == "Bad Request"
        self(404) == "Not Found"
        self(500) == "Internal Server Error"
        self(999) == "Unknown"
    }
}

pub fn safe_divide(a: Number, b: Number) -> Number, err {
    if b == 0 { return err.division_by_zero }
    return a / b

    test {
        self(10, 2) == 5
        self(10, 0) is err.division_by_zero
        self(0, 5) == 0
    }
}

pub fn sum_array(nums: Number) -> Number {
    // Takes a dummy param — arrays not typed yet in params
    const arr = [1, 2, 3, 4, 5]
    let total = 0
    for n in arr {
        total = total + n
    }
    return total

    test {
        self(0) == 15
    }
}
