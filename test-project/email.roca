// Email type — validates format, controls what operations are allowed

pub struct Email {
    value: String

    validate(raw: String) -> Email, err {
        err empty = "email cannot be empty"
        err no_at = "email must contain @"
        err too_short = "email too short"
    }

    domain() -> String
}{
    fn validate(raw: String) -> Email, err {
        if raw == "" { return err.empty }
        if raw.length < 3 { return err.too_short }
        if !raw.includes("@") { return err.no_at }
        return Email { value: raw }

        crash {
            raw.includes -> halt
        }

        test {
            self("cam@test.com") is Ok
            self("") is err.empty
            self("ab") is err.too_short
            self("nope") is err.no_at
        }
    }

    fn domain() -> String {
        const parts = self.value.split("@")
        return parts[1]

        crash {
            self.value.split -> halt
        }

        // Instance method — tested via integration, not inline
        test {
        }
    }
}
