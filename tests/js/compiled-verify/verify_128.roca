/// A user
        pub struct User {
            name: String
            create(data: String) -> User, err {
                err invalid = "bad"
            }
        }{
            pub fn create(data: String) -> User, err {
                if data == "" { return err.invalid }
                return User { name: data }
                test {
                    self("cam") is Ok
                    self("") is err.invalid
                }
            }
        }
        User satisfies Deserializable<User> {
            fn parse(data: String) -> User, err {
                return User { name: data }
                test { self("cam") is Ok }
            }
        }