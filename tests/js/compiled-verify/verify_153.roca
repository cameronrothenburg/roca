contract StatusCode { 200 400 500 }

        pub fn status_message(code: Number) -> String {
            if code == 200 { return "ok" }
            if code == 400 { return "bad request" }
            if code == 500 { return "server error" }
            return "unknown"
            test {
                self(200) == "ok"
                self(400) == "bad request"
                self(999) == "unknown"
            }
        }