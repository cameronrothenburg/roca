// Integration: multi-level error propagation with crash blocks

pub fn validate(n: Number { min: 0, max: 1000 }) -> Number, err {
    if n == 0 { return err.zero }
    return n
}

pub fn transform(n: Number) -> Number, err {
    if n > 500 { return err.too_large }
    return n * 2
}

pub fn pipeline(n: Number) -> Number {
    let raw, failed = validate(n)
    if failed { return 0 }
    let result, err2 = transform(raw)
    if err2 { return raw }
    return result
crash {
    validate -> fallback(0)
    transform -> log |> fallback(0)
}}

test {
    pipeline(5) == 10
    pipeline(0) == 0
    pipeline(600) == 600
    pipeline(-1) == 0
}
