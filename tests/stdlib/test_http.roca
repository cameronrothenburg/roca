// Deep stdlib tests: Http contract — crash strategies on network calls
// In embedded V8, fetch is not available. Tests verify crash handling.

import { Http } from std::http

/// Test: get with fallback recovers from missing fetch
pub fn test_get_fallback(url: String) -> String {
    const response = Http.get(url)
    return "got response"
crash {
    Http.get -> fallback("")
}
    test {
        self("https://example.com") == "got response"
    }
}

/// Test: post with fallback recovers
pub fn test_post_fallback(url: String, body: String) -> String {
    const response = Http.post(url, body)
    return "posted"
crash {
    Http.post -> fallback("")
}
    test {
        self("https://api.example.com", "data") == "posted"
    }
}
