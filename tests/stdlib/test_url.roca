// Deep stdlib tests: Url contract — parse errors and crash strategies

import { Url } from std::url

/// Test: parse with halt propagates error on invalid input
pub fn test_parse_halt(raw: String) -> String, err {
    const parsed = Url.parse(raw)
    return "ok"
crash {
    Url.parse -> halt
}
    test {
        self("not a url") is err.parse_failed
    }
}

/// Test: parse with fallback recovers
pub fn test_parse_fallback(raw: String) -> String {
    const parsed = Url.parse(raw)
    return "parsed"
crash {
    Url.parse -> fallback("")
}
    test {
        self("not a url") == "parsed"
    }
}
