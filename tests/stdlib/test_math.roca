// Deep stdlib tests: Math contract

import { Math } from std::math

/// Test
pub fn test_floor(n: Number) -> Number {
    return Math.floor(n)
    test {
        self(3.7) == 3
        self(-1.2) == -2
        self(0) == 0
        self(5) == 5
    }
}

/// Test
pub fn test_ceil(n: Number) -> Number {
    return Math.ceil(n)
    test {
        self(3.2) == 4
        self(-1.8) == -1
        self(0) == 0
        self(5) == 5
    }
}

/// Test
pub fn test_round(n: Number) -> Number {
    return Math.round(n)
    test {
        self(3.4) == 3
        self(3.5) == 4
        self(-0.5) == 0
    }
}

/// Test
pub fn test_abs(n: Number) -> Number {
    return Math.abs(n)
    test {
        self(-5) == 5
        self(5) == 5
        self(0) == 0
    }
}

/// Test
pub fn test_sqrt(n: Number) -> Number {
    return Math.sqrt(n)
    test {
        self(4) == 2
        self(9) == 3
        self(0) == 0
        self(1) == 1
    }
}

/// Test
pub fn test_pow(base: Number, exp: Number) -> Number {
    return Math.pow(base, exp)
    test {
        self(2, 3) == 8
        self(5, 0) == 1
        self(10, 1) == 10
        self(2, 10) == 1024
    }
}

/// Test
pub fn test_min(a: Number, b: Number) -> Number {
    return Math.min(a, b)
    test {
        self(3, 5) == 3
        self(5, 3) == 3
        self(5, 5) == 5
        self(-1, 1) == -1
    }
}

/// Test
pub fn test_max(a: Number, b: Number) -> Number {
    return Math.max(a, b)
    test {
        self(3, 5) == 5
        self(5, 3) == 5
        self(5, 5) == 5
        self(-1, 1) == 1
    }
}

/// Test
pub fn test_combined(n: Number) -> Number {
    const floored = Math.floor(n)
    const absolute = Math.abs(floored)
    return Math.pow(absolute, 2)
    test {
        self(3.7) == 9
        self(-2.1) == 9
        self(0) == 0
    }
}
