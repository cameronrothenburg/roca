// Integration: structs with methods and constraints

pub struct Point {
    x: Number { min: -1000, max: 1000, default: 0 }
    y: Number { min: -1000, max: 1000, default: 0 }
}{
    fn distanceFromOrigin() -> Number {
        return (self.x * self.x + self.y * self.y)
    }

    fn translate(dx: Number, dy: Number) -> Number {
        self.x = self.x + dx
        self.y = self.y + dy
        return self.x + self.y
    }
}

pub fn create_and_measure() -> Number {
    const p = Point { x: 3, y: 4 }
    return Point.distanceFromOrigin(p)
}

pub fn translate_point() -> Number {
    let p = Point { x: 0, y: 0 }
    return Point.translate(p, 5, 10)
}

test {
    create_and_measure() == 25
    translate_point() == 15
}
