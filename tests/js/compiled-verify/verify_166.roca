extern contract Logger {
            info(msg: String) -> Ok
        }

        pub struct App {
            logger: Logger
        }{}

        pub fn greet(app: App, name: String) -> String {
            app.logger.info("greeting " + name)
            return "Hello " + name
            crash { app.logger.info -> skip }
            test { self(App { logger: null }, "cam") == "Hello cam" }
        }