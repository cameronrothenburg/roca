pub fn categorize(code: Number) -> String, err {
            return match code {
                200 => "ok"
                404 => err.not_found
                500 => err.server_error
                _ => err.unknown
            }
            test {
                self(200) == "ok"
                self(404) is err.not_found
                self(500) is err.server_error
                self(999) is err.unknown
            }
        }