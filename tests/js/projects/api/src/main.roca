import { ApiResponse } from "./types.roca"
import { get_user, validate_name } from "./handlers.roca"

/// Route a request
pub fn handle(method: String, path: String) -> ApiResponse {
    if method == "GET" {
        return get_user("default")
    }
    return ApiResponse.fail("not found")
test {
    self("GET", "/users") == ApiResponse { status: 200, body: "default" }
    self("DELETE", "/users") == ApiResponse { status: 400, body: "not found" }
}}
