pub enum Color {
            red = "red"
            green = "green"
            blue = "blue"
        }

        pub fn describe(c: String) -> String {
            return match c {
                Color.red => "warm"
                Color.blue => "cool"
                _ => "other"
            }
            test { self("red") == "warm" self("blue") == "cool" self("green") == "other" }
        }