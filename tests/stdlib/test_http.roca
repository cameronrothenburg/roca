// Deep stdlib tests: Http contract — network errors, retry, crash strategies

import { Http } from std::http

/// Test
pub fn test_get_with_fallback(url: String) -> String {
    const response = Http.get(url)
    const body = Http.text(response)
    return body
crash {
    Http.get -> fallback(Http)
    Http.text -> fallback("error")
}
    test {
        self("https://example.com") == "mock body"
    }
}

/// Test
pub fn test_get_halt(url: String) -> String, err {
    const response = Http.get(url)
    const body = Http.text(response)
    return body
crash {
    Http.get -> halt
    Http.text -> halt
}
    test {
        self("https://example.com") is Ok
    }
}

/// Test
pub fn test_post_with_fallback(url: String, body: String) -> String {
    const response = Http.post(url, body)
    const text = Http.text(response)
    return text
crash {
    Http.post -> fallback(Http)
    Http.text -> fallback("")
}
    test {
        self("https://api.example.com", "data") == "mock body"
    }
}

/// Test
pub fn test_get_detailed(url: String) -> String, err {
    const response = Http.get(url)
    const body = Http.text(response)
    return body
crash {
    Http.get {
        err.network -> log |> halt
        err.abort -> fallback(Http)
    }
    Http.text -> halt
}
    test {
        self("https://example.com") is Ok
    }
}

/// Test
pub fn test_get_retry(url: String) -> String, err {
    const response = Http.get(url)
    const body = Http.text(response)
    return body
crash {
    Http.get -> retry(3, 100) |> halt
    Http.text -> halt
}
    test {
        self("https://example.com") is Ok
    }
}

/// Test
pub fn test_status_check(url: String) -> Number {
    const response = Http.get(url)
    return Http.status(response)
crash {
    Http.get -> fallback(Http)
}
    test {
        self("https://example.com") == 200
    }
}

/// Test
pub fn test_ok_check(url: String) -> Bool {
    const response = Http.get(url)
    return Http.ok(response)
crash {
    Http.get -> fallback(Http)
}
    test {
        self("https://example.com") is Ok
    }
}
