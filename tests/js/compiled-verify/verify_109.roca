pub fn grid(rows: Number, cols: Number) -> Number {
            let count = 0
            let r = 0
            while r < rows {
                let c = 0
                while c < cols {
                    count = count + 1
                    c = c + 1
                }
                r = r + 1
            }
            return count
            test { self(3, 4) == 12 }
        }