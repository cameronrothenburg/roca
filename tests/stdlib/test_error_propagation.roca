// Deep tests: error propagation through crash blocks at multiple levels

/// External validator
pub extern fn validate(n: Number) -> Number, err {
    err negative = "value is negative"
    err too_large = "value too large"
    mock { validate -> 42 }
}

/// External transformer
pub extern fn transform(n: Number) -> Number, err {
    err overflow = "overflow"
    mock { transform -> 99 }
}

/// Test: both crash with fallback — always recovers
pub fn both_fallback(n: Number) -> Number {
    const valid = validate(n)
    const result = transform(valid)
    return result
crash {
    validate -> fallback(0)
    transform -> fallback(0)
}
    test {
        self(5) == 99
    }
}

/// Test: validate halts, transform fallbacks — error propagates from validate
pub fn halt_then_fallback(n: Number) -> Number, err {
    const valid = validate(n)
    const result = transform(valid)
    return result
crash {
    validate -> halt
    transform -> fallback(0)
}
    test {
        self(5) is Ok
    }
}

/// Test: both halt — any error propagates to caller
pub fn both_halt(n: Number) -> Number, err {
    const valid = validate(n)
    const result = transform(valid)
    return result
crash {
    validate -> halt
    transform -> halt
}
    test {
        self(5) is Ok
    }
}

/// Test: detailed crash — different strategy per error type
pub fn detailed_handling(n: Number) -> Number, err {
    const valid = validate(n)
    return valid
crash {
    validate {
        err.negative -> fallback(0)
        err.too_large -> halt
    }
}
    test {
        self(5) is Ok
    }
}

/// Test: log then halt chain
pub fn log_then_halt(n: Number) -> Number, err {
    const valid = validate(n)
    return valid
crash {
    validate -> log |> halt
}
    test {
        self(5) is Ok
    }
}
