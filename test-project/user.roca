// User type — composed from Email, validates all fields

import { Email } from "./email.roca"

pub struct User {
    name: String
    email: Email
    age: Number

    validate(name: String, email_raw: String, age: Number) -> User, err {
        err missing_name = "name is required"
        err invalid_age = "age must be between 0 and 150"
        err bad_email = "email is invalid"
    }

    display() -> String
    is_adult() -> Bool
}{
    fn validate(name: String, email_raw: String, age: Number) -> User, err {
        if name == "" { return err.missing_name }
        if age < 0 { return err.invalid_age }
        if age > 150 { return err.invalid_age }

        let email_result, email_err = Email.validate(email_raw)
        if email_err { return err.bad_email }

        return User { name: name, email: email_result, age: age }

        crash {
            Email.validate -> halt
        }

        test {
            self("cam", "cam@test.com", 25) is Ok
            self("", "cam@test.com", 25) is err.missing_name
            self("cam", "bad", 25) is err.bad_email
            self("cam", "cam@test.com", -1) is err.invalid_age
            self("cam", "cam@test.com", 200) is err.invalid_age
        }
    }

    fn display() -> String {
        return self.name + " (" + self.age.toString() + ")"

        crash {
            self.age.toString -> halt
        }

        test {}
    }

    fn is_adult() -> Bool {
        if self.age >= 18 { return true }
        return false

        test {}
    }
}
