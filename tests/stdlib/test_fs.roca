// Deep stdlib tests: Fs contract — crash strategies on I/O errors
// Note: embedded V8 has no Node APIs, so all Fs calls fail with err.io.
// Tests verify crash blocks handle these failures correctly.

import { Fs } from std::fs

/// Test: fallback recovers from I/O error
pub fn test_read_with_fallback(path: String) -> String {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> fallback("default content")
}
    test {
        self("/any") == "default content"
    }
}

/// Test: skip continues past I/O error
pub fn test_read_with_skip(path: String) -> String {
    const content = Fs.readFile(path)
    return "done"
crash {
    Fs.readFile -> skip
}
    test {
        self("/any") == "done"
    }
}

/// Test: halt propagates I/O error
pub fn test_read_halt(path: String) -> String, err {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> halt
}
    test {
        self("/any") is err.io
    }
}

/// Test: detailed crash — different strategies per error
pub fn test_read_detailed(path: String) -> String {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile {
        err.not_found -> fallback("missing")
        err.permission -> fallback("denied")
        default -> fallback("error")
    }
}
    test {
        self("/any") == "error"
    }
}

/// Test: write halt propagates error
pub fn test_write_halt(path: String, content: String) -> Ok, err {
    Fs.writeFile(path, content)
    return Ok
crash {
    Fs.writeFile -> halt
}
    test {
        self("/tmp/test", "data") is err.io
    }
}

/// Test: readDir halt propagates error
pub fn test_readdir_halt(path: String) -> Number, err {
    const entries = Fs.readDir(path)
    return entries.length
crash {
    Fs.readDir -> halt
}
    test {
        self("/any") is err.io
    }
}
