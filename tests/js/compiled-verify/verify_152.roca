/// Validates input
        pub struct Validate {
            call(s: String) -> String, err {
                err empty = "empty"
                err invalid = "invalid"
            }
        }{
            pub fn call(s: String) -> String, err {
                if s == "" { return err.empty }
                if s == "bad" { return err.invalid }
                return s
                test {
                    self("ok") == "ok"
                    self("") is err.empty
                    self("bad") is err.invalid
                }
            }
        }