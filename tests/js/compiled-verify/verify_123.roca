contract Stringable { to_string() -> String }
        contract Measurable { len() -> Number }

        pub struct Name {
            value: String
        }{}

        Name satisfies Stringable {
            fn to_string() -> String {
                return self.value
                test { self() == "test" }
            }
        }

        Name satisfies Measurable {
            fn len() -> Number {
                return self.value.length
                test { self() == 4 }
            }
        }