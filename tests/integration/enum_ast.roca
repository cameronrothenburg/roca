// Integration: algebraic enums for AST-like structures

enum Token {
    Number(Number)
    Plus
    Minus
    Mul
}

pub fn tokenize(code: Number) -> Token {
    return match code {
        1 => Token.Number(42)
        2 => Token.Plus
        3 => Token.Minus
        _ => Token.Mul
    }
}

pub fn eval_binary(left: Number, op: Token, right: Number) -> Number {
    return match op {
        Token.Plus => left + right
        Token.Minus => left - right
        Token.Mul => left * right
        _ => 0
    }
}

pub fn run() -> Number {
    const op = tokenize(2)
    return eval_binary(10, op, 5)
}

test {
    run() == 15
    eval_binary(3, Token.Mul, 4) == 12
    eval_binary(10, Token.Minus, 3) == 7
}
