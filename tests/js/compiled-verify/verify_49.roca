/// Flaky operation
        pub struct Flaky {
            call(s: String) -> String, err {
                err fail = "fail"
            }
        }{
            pub fn call(s: String) -> String, err {
                if s == "" { return err.fail }
                return "ok"
                test { self("ok") == "ok" self("") is err.fail }
            }
        }

        /// Calls flaky
        pub fn caller() -> String {
            const result = Flaky.call("ok")
            return result
            crash { Flaky.call -> retry(3, 0) |> fallback("failed") }
            test { self() == "ok" }
        }