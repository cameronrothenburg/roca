// Deep tests: nested crash blocks — error propagation through 3 levels
// Note: inline tests run against mocks which return success values.
// Error injection is handled by the auto-generated error mock tests.

import { Fs } from std::fs

/// Test: level C halts errors from Fs
pub fn level_c(path: String) -> String, err {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> halt
}
    test {
        self("/any") is Ok
    }
}

/// Test: level B calls C, provides fallback on error
pub fn level_b(path: String) -> String {
    const result = level_c(path)
    return result
crash {
    level_c -> fallback("b-default")
}
    test {
        self("/any") == ""
    }
}

/// Test: level A calls B which always succeeds
pub fn level_a(path: String) -> String {
    const text = level_b(path)
    return text.toUpperCase()
    test {
        self("/any") == ""
    }
}

/// Test: strict C halts
pub fn strict_c(path: String) -> String, err {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> halt
}
    test {
        self("/any") is Ok
    }
}

/// Test: strict B halts from C
pub fn strict_b(path: String) -> String, err {
    const result = strict_c(path)
    return result
crash {
    strict_c -> halt
}
    test {
        self("/any") is Ok
    }
}

/// Test: strict A halts from B
pub fn strict_a(path: String) -> String, err {
    const text = strict_b(path)
    return text
crash {
    strict_b -> halt
}
    test {
        self("/any") is Ok
    }
}
