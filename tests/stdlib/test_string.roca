// Deep stdlib tests: String contract methods

/// Test
pub fn test_trim(s: String) -> String {
    return s.trim()
    test {
        self("  hello  ") == "hello"
        self("") == ""
        self("no-space") == "no-space"
        self("  ") == ""
    }
}

/// Test
pub fn test_toUpperCase(s: String) -> String {
    return s.toUpperCase()
    test {
        self("hello") == "HELLO"
        self("") == ""
        self("ALREADY") == "ALREADY"
        self("123") == "123"
    }
}

/// Test
pub fn test_toLowerCase(s: String) -> String {
    return s.toLowerCase()
    test {
        self("HELLO") == "hello"
        self("") == ""
        self("already") == "already"
    }
}

/// Test
pub fn test_includes(s: String, search: String) -> Bool {
    return s.includes(search)
    test {
        self("hello world", "world") is Ok
        self("hello", "xyz") is Ok
    }
}

/// Test
pub fn test_startsWith(s: String, prefix: String) -> Bool {
    return s.startsWith(prefix)
    test {
        self("hello", "hel") is Ok
        self("hello", "xyz") is Ok
    }
}

/// Test
pub fn test_endsWith(s: String, suffix: String) -> Bool {
    return s.endsWith(suffix)
    test {
        self("hello", "llo") is Ok
        self("hello", "xyz") is Ok
    }
}

/// Test
pub fn test_indexOf(s: String, search: String) -> Number {
    return s.indexOf(search)
    test {
        self("hello", "ll") == 2
        self("hello", "xyz") == -1
        self("hello", "") == 0
    }
}

/// Test
pub fn test_charAt(s: String, i: Number) -> String {
    return s.charAt(i)
    test {
        self("hello", 0) == "h"
        self("hello", 4) == "o"
    }
}

/// Test
pub fn test_slice(s: String, start: Number, end: Number) -> String {
    return s.slice(start, end)
    test {
        self("hello", 0, 3) == "hel"
        self("hello", 1, 4) == "ell"
    }
}

/// Test
pub fn test_split(s: String, sep: String) -> Number {
    const parts = s.split(sep)
    return parts.length
    test {
        self("a,b,c", ",") == 3
        self("hello", ",") == 1
    }
}

/// Test
pub fn test_length(s: String) -> Number {
    return s.length
    test {
        self("hello") == 5
        self("") == 0
        self("  ") == 2
    }
}

/// Test
pub fn test_chain(s: String) -> String {
    return s.trim().toUpperCase()
    test {
        self("  hello  ") == "HELLO"
        self("  a b  ") == "A B"
    }
}
