// Deep tests: every crash strategy on Fs (I/O errors in embedded V8)

import { Fs } from std::fs

/// Test: fallback — recover with default value
pub fn crash_fallback(path: String) -> String {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> fallback("default")
}
    test {
        self("/any") == "default"
    }
}

/// Test: skip — continue past error
pub fn crash_skip(path: String) -> String {
    const content = Fs.readFile(path)
    return "completed"
crash {
    Fs.readFile -> skip
}
    test {
        self("/any") == "completed"
    }
}

/// Test: halt — propagate error to caller
pub fn crash_halt(path: String) -> String, err {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> halt
}
    test {
        self("/any") is err.io
    }
}

/// Test: log then fallback
pub fn crash_log_fallback(path: String) -> String {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> log |> fallback("logged-and-recovered")
}
    test {
        self("/any") == "logged-and-recovered"
    }
}

/// Test: log then halt
pub fn crash_log_halt(path: String) -> String, err {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile -> log |> halt
}
    test {
        self("/any") is err.io
    }
}

/// Test: detailed — different strategy per error type
pub fn crash_detailed(path: String) -> String {
    const content = Fs.readFile(path)
    return content
crash {
    Fs.readFile {
        err.not_found -> fallback("not found")
        err.permission -> fallback("denied")
        default -> fallback("other error")
    }
}
    test {
        self("/any") == "other error"
    }
}
