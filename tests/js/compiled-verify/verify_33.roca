pub fn process() -> String {
            const nums = [1, 2, 3, 4, 5, 6]
            const result = nums.filter(fn(x) -> x > 2).map(fn(x) -> x * 10)
            return result.join(",")
            crash {
                nums.filter -> skip
                result.join -> skip
            }
            test { self() == "30,40,50,60" }
        }