// Deep stdlib tests: Array contract

/// Test
pub fn test_length() -> Number {
    const arr = [10, 20, 30]
    return arr.length
    test { self() == 3 }
}

/// Test
pub fn test_includes_found() -> Bool {
    const arr = [1, 2, 3]
    return arr.includes(2)
    test { self() is Ok }
}

/// Test
pub fn test_indexOf_found() -> Number {
    const arr = [10, 20, 30]
    return arr.indexOf(20)
    test { self() == 1 }
}

/// Test
pub fn test_join() -> String {
    const arr = [1, 2, 3]
    return arr.join("-")
    test { self() == "1-2-3" }
}

/// Test
pub fn test_push() -> Number {
    let arr = [1, 2]
    arr.push(3)
    return arr.length
    test { self() == 3 }
}

/// Test
pub fn test_map() -> Number {
    const arr = [1, 2, 3]
    const doubled = arr.map(fn(x) -> x * 2)
    return doubled[0] + doubled[1] + doubled[2]
    test { self() == 12 }
}

/// Test
pub fn test_filter() -> Number {
    const arr = [1, 2, 3, 4, 5]
    const evens = arr.filter(fn(x) -> x > 3)
    return evens.length
    test { self() == 2 }
}

/// Test
pub fn test_map_filter_chain() -> Number {
    const arr = [1, 2, 3, 4, 5]
    const result = arr.map(fn(x) -> x * 10).filter(fn(x) -> x > 25)
    return result.length
    test { self() == 3 }
}

/// Test
pub fn test_for_loop_sum() -> Number {
    const arr = [10, 20, 30, 40]
    let total = 0
    for item in arr {
        total = total + item
    }
    return total
    test { self() == 100 }
}

/// Test
pub fn test_index_access() -> Number {
    const arr = [100, 200, 300]
    return arr[1]
    test { self() == 200 }
}
