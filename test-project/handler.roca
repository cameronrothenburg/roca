// Request handler — demonstrates crash blocks, error handling, composition

import { User } from "./user.roca"
import { status_message } from "./utils.roca"

pub struct Response {
    status: Number
    body: String

    create(status: Number, body: String) -> Response
}{
    fn create(status: Number, body: String) -> Response {
        return Response { status: status, body: body }

        test {
        }
    }
}

pub fn handle_register(name: String, email: String, age: Number) -> Response {
    let user, user_err = User.validate(name, email, age)

    if user_err {
        const error_msg = user_err.message
        return Response.create(400, error_msg)
    }

    const greeting = "Welcome " + user.display()
    return Response.create(200, greeting)

    crash {
        User.validate -> halt
        user.display -> halt
        Response.create -> halt
        user_err.message -> halt
    }

    test {
    }
}

pub fn handle_status(code: Number) -> Response {
    const msg = status_message(code)
    return Response.create(code, msg)

    crash {
        status_message -> halt
        Response.create -> halt
    }

    test {
    }
}
